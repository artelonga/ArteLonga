{
  "name": "artelonga",
  "private": true,
  "type": "module",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.59.1",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "husky": "^9.1.0",
    "js-yaml": "^4.1.0",
    "serve": "^14.2.6",
    "typescript": "^5.4.0",
    "vite": "^6.3.5"
  },
  "scripts": {
    "build": "vite build --config vite.renderer.config.ts && vite build",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:showcase": "vite build",
    "dev": "vite",
    "validate-yaml": "node tools/validate-yaml.mjs",
    "bake-people": "node tools/bake-people.mjs",
    "bake-communities": "node tools/bake-communities.mjs",
    "bake-services": "node tools/bake-services.mjs",
    "bake-missions": "node tools/bake-missions.mjs",
    "bake-solutions": "node tools/bake-solutions.mjs",
    "bake-finances": "node tools/bake-finances.mjs",
    "bake-state": "node tools/bake-state.mjs",
    "bake-sitemap": "node tools/bake-sitemap.mjs",
    "bake": "npm run bake-people && npm run bake-communities && npm run bake-services && npm run bake-missions && npm run bake-solutions && npm run bake-finances && npm run bake-sitemap",
    "audit-shells": "node tools/audit-shells.mjs",
    "audit-consistency": "node tools/audit-consistency.mjs",
    "audit-handles": "node tools/audit-handles.mjs",
    "audit": "npm run audit-shells && npm run audit-consistency && npm run audit-handles",
    "typecheck": "tsc --noEmit",
    "pre-commit": "node tools/pre-commit-check.mjs",
    "test": "playwright test",
    "ship": "node tools/al-ship.mjs",
    "prepare": "husky"
  }
}
