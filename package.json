{
  "name": "artelonga",
  "private": true,
  "type": "module",
  "devDependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "husky": "^9.1.0",
    "js-yaml": "^4.1.0",
    "typescript": "^5.4.0",
    "vite": "^6.3.5"
  },
  "scripts": {
    "build": "vite build --config vite.renderer.config.ts && vite build",
    "build:renderer": "vite build --config vite.renderer.config.ts",
    "build:showcase": "vite build",
    "dev": "vite",
    "validate-yaml": "node tools/validate-yaml.mjs",
    "bake-people": "node tools/bake-people.mjs",
    "bake-communities": "node tools/bake-communities.mjs",
    "bake-state": "node tools/bake-state.mjs",
    "bake": "npm run bake-people && npm run bake-communities",
    "audit-shells": "node tools/audit-shells.mjs",
    "audit-consistency": "node tools/audit-consistency.mjs",
    "audit-handles": "node tools/audit-handles.mjs",
    "audit": "npm run audit-shells && npm run audit-consistency && npm run audit-handles",
    "typecheck": "tsc --noEmit",
    "pre-commit": "node tools/pre-commit-check.mjs",
    "ship": "node tools/al-ship.mjs",
    "prepare": "husky"
  }
}
