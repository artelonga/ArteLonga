#!/usr/bin/env sh
# Pre-commit hook — enforça que data.js esteja em sync com YAMLs.
# Wired via husky. Roda automaticamente em `git commit`.
#
# Pra desabilitar temporariamente em emergência (não recomendado):
#   git commit --no-verify
#
# Pra desabilitar permanentemente: remove esse arquivo + reverte
# package.json (devDep husky + script prepare).

. "$(dirname "$0")/_/husky.sh"

node tools/pre-commit-check.mjs

# secure-publish gate (AGPL public repo): block sensitive content from being
# committed. Toggle in secure-publish.config.json (enforce) or SECURE_PUBLISH=off.
node tools/secure-publish.mjs scan --staged
